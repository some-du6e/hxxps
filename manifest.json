{
  "manifest_version": 3,
  "name": "hxxps",
  "description": "Converts hxxps and hxxp links to normal openable URLs for easy access",
  "version": "1.0",
  "permissions": ["contextMenus", "tabs", "scripting", "activeTab", "clipboardWrite", "windows"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
